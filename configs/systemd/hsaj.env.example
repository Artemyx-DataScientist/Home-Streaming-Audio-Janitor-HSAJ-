# Shared settings for hsaj-bridge.service and hsaj-core.service.
# Copy this file to /etc/hsaj/hsaj.env and adjust it for your system.

HSAJ_ROOT=/opt/hsaj
HSAJ_CONFIG=/etc/hsaj/hsaj.yaml
PATH=/opt/hsaj/core/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin

BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8080
BRIDGE_WS_PATH=/events
BRIDGE_SHARED_SECRET=
HSAJ_BRIDGE_HTTP=http://127.0.0.1:8080
HSAJ_BRIDGE_WS=ws://127.0.0.1:8080/events
HSAJ_BRIDGE_TOKEN=
